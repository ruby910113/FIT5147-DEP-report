dataset = "Housing finance",
start_ym = paste0(year(min(date)), "/", month(min(date))),
end_ym = paste0(year(max(date)), "/", month(max(date))),
frequency = "Quarterly",
time_period = paste0(
min(financial_year), " to ",
max(financial_year))),
wage_price_index %>%
distinct(year, month, financial_year) %>%
mutate(date = make_date(year, month, 1)) %>%
summarise(
dataset = "Wage price index",
start_ym = paste0(year(min(date)), "/", month(min(date))),
end_ym = paste0(year(max(date)), "/", month(max(date))),
frequency = "Quarterly",
time_period = paste0(
min(financial_year), " to ",
max(financial_year))))
data_time_summary %>%
kable(
caption = "Summary of time structure across the datasets",
col.names = c("Dataset", "Start (Year/Month)", "End (Year/Month)", "Frequency", "Time period")) %>%
kable_styling(full_width = FALSE)
#| label: fig-time-coverage
period_df <- bind_rows(
overseas_migration %>%
distinct(financial_year) %>%
summarise(dataset = "Overseas migration", start_fy = min(financial_year), end_fy = max(financial_year)),
housing_finance %>%
distinct(financial_year) %>%
summarise(dataset = "Housing finance", start_fy = min(financial_year), end_fy = max(financial_year)),
wage_price_index %>%
distinct(financial_year) %>%
summarise(dataset = "Wage price index", start_fy = min(financial_year), end_fy = max(financial_year))) %>%
mutate(start_num = as.numeric(str_sub(start_fy, 1, 4)), end_num = as.numeric(str_sub(end_fy, 1, 4)))
overlap_start <- max(period_df$start_num)
overlap_end <- min(period_df$end_num)
fy_breaks <- seq(floor(min(period_df$start_num)), ceiling(max(period_df$end_num)), by = 4)
fy_labels <- paste0(fy_breaks, "-", str_sub(fy_breaks + 1, 3, 4))
ggplot(period_df, aes(y = fct_rev(dataset))) +
annotate("rect", xmin = overlap_start, xmax = overlap_end, ymin = -Inf, ymax = Inf, fill = "grey80", alpha = 0.5) +
geom_segment(aes(x = start_num, xend = end_num, yend = fct_rev(dataset), colour = dataset), linewidth = 1.4) +
geom_point(aes(x = start_num, colour = dataset), size = 3) +
geom_point(aes(x = end_num, colour = dataset), size = 3) +
annotate("text", x = (overlap_start + overlap_end) / 2, y = 3.25, label = "Grey area: common comparison period", size = 3.6, colour = "grey20") +
scale_x_continuous(breaks = fy_breaks, labels = fy_labels, expand = expansion(mult = c(0.02, 0.02))) +
labs(title = "Financial-year coverage across the datasets", x = "Financial year", y = NULL) +
theme_minimal(base_size = 12) +
theme(panel.grid.major.y = element_blank(), panel.grid.minor = element_blank(), legend.position = "none")
period_df <- bind_rows(
overseas_migration %>%
distinct(financial_year) %>%
summarise(
dataset = "Overseas migration",
start_fy = min(financial_year),
end_fy = max(financial_year)
),
housing_finance %>%
distinct(financial_year) %>%
summarise(
dataset = "Housing finance",
start_fy = min(financial_year),
end_fy = max(financial_year)
),
wage_price_index %>%
distinct(financial_year) %>%
summarise(
dataset = "Wage price index",
start_fy = min(financial_year),
end_fy = max(financial_year)
)
) %>%
mutate(
start_num = as.numeric(str_sub(start_fy, 1, 4)),
end_num = as.numeric(str_sub(end_fy, 1, 4))
)
overlap_start <- max(period_df$start_num)
overlap_end <- min(period_df$end_num)
fy_breaks <- seq(
floor(min(period_df$start_num)),
ceiling(max(period_df$end_num)),
by = 4
)
fy_labels <- paste0(
fy_breaks, "-",
str_sub(fy_breaks + 1, 3, 4)
)
ggplot(period_df, aes(y = fct_rev(dataset))) +
annotate(
"rect",
xmin = overlap_start,
xmax = overlap_end,
ymin = -Inf,
ymax = Inf,
fill = "grey80",
alpha = 0.5
) +
geom_segment(
aes(x = start_num, xend = end_num, yend = fct_rev(dataset), colour = dataset),
linewidth = 1.4
) +
geom_point(
aes(x = start_num, colour = dataset),
size = 3
) +
geom_point(
aes(x = end_num, colour = dataset),
size = 3
) +
annotate(
"text",
x = (overlap_start + overlap_end) / 2,
y = 3.25,
label = "Grey area: common comparison period",
size = 3.6,
colour = "grey20"
) +
scale_x_continuous(
breaks = fy_breaks,
labels = fy_labels,
limits = c(min(period_df$start_num) - 0.5, max(period_df$end_num) + 0.5),
expand = c(0, 0)
) +
labs(
title = "Financial-year coverage across the datasets",
x = "Financial year",
y = NULL
) +
theme_minimal(base_size = 12) +
theme(
panel.grid.major.y = element_blank(),
panel.grid.minor = element_blank(),
legend.position = "none"
)
