#| label: fig-q3-national
#| fig-cap: National comparison of investor lending, owner-occupier lending, and positive foreign-born migrant inflows, 2004-05 to 2024-25. All series are standardised to 2004-05 = 100 to highlight differences in relative movement over time.
#| fig-width: 10
#| fig-height: 7
q3_series_colors <- c(
"Investor lending value" = "#d95f02",
"Owner-occupier lending value" = "#1b9e77",
"Positive migrant inflows" = "black",
"Investor share of lending" = "#7570b3"
)
p_q3_value <- ggplot(q3_nat_value_long, aes(x = start_year, y = index_value, colour = series)) +
geom_line(linewidth = 1) +
scale_colour_manual(values = q3_series_colors, name = NULL) +
scale_x_continuous(
breaks = seq(2004, 2024, by = 4),
labels = function(x) paste0(x, "-", str_sub(x + 1, 3, 4))
) +
labs(
title = "Indexed lending values and positive migrant inflows",
x = NULL,
y = "Index (2004-05 = 100)"
) +
theme_minimal(base_size = 11) +
theme(
panel.grid.minor = element_blank(),
plot.title = element_text(face = "bold", hjust = 0.5)
)
p_q3_share <- ggplot(q3_nat_share_long, aes(x = start_year, y = index_value, colour = series)) +
geom_line(linewidth = 1) +
scale_colour_manual(values = q3_series_colors, name = NULL) +
scale_x_continuous(
breaks = seq(2004, 2024, by = 4),
labels = function(x) paste0(x, "-", str_sub(x + 1, 3, 4))
) +
labs(
title = "Indexed investor share and positive migrant inflows",
x = "Financial year",
y = "Index (2004-05 = 100)"
) +
theme_minimal(base_size = 11) +
theme(
panel.grid.minor = element_blank(),
plot.title = element_text(face = "bold", hjust = 0.5)
)
(p_q3_value / p_q3_share) +
plot_layout(guides = "collect") +
plot_annotation(
