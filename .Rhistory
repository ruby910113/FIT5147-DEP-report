#| label: q3-prepare-data
#| include: false
# Positive foreign-born migrant inflows by state and year
q3_migration_state <- overseas_migration %>%
filter(state %in% state_levels, country_of_birth != "Australia") %>%
mutate(pos_nom = pmax(net_overseas_migration, 0)) %>%
group_by(financial_year, state) %>%
summarise(pos_nom = sum(pos_nom, na.rm = TRUE), .groups = "drop") %>%
arrange(state, financial_year) %>%
group_by(state) %>%
mutate(
migration_growth_pct = (pos_nom / lag(pos_nom) - 1) * 100,
start_year = as.integer(str_sub(financial_year, 1, 4))
) %>%
ungroup()
# Positive foreign-born migrant inflows for Australia
q3_migration_nat <- overseas_migration %>%
filter(state == "Australia", country_of_birth != "Australia") %>%
mutate(pos_nom = pmax(net_overseas_migration, 0)) %>%
group_by(financial_year) %>%
summarise(pos_nom = sum(pos_nom, na.rm = TRUE), .groups = "drop") %>%
mutate(start_year = as.integer(str_sub(financial_year, 1, 4)))
# Annual investor and owner-occupier lending by state
q3_hf_state <- housing_finance %>%
filter(
state %in% state_levels,
value_type == "Value",
series_type == "Original"
) %>%
group_by(financial_year, state, loan_type) %>%
summarise(annual_value = sum(housing_finance, na.rm = TRUE), .groups = "drop") %>%
pivot_wider(names_from = loan_type, values_from = annual_value) %>%
mutate(
total_value = investor + owner_occupier,
investor_share = investor / total_value
) %>%
arrange(state, financial_year) %>%
group_by(state) %>%
mutate(
investor_growth_pct = (investor / lag(investor) - 1) * 100,
owner_growth_pct = (owner_occupier / lag(owner_occupier) - 1) * 100,
investor_gap_pct = investor_growth_pct - owner_growth_pct,
start_year = as.integer(str_sub(financial_year, 1, 4))
) %>%
ungroup()
# Annual investor and owner-occupier lending for Australia
q3_hf_nat <- housing_finance %>%
filter(
state == "Total Australia",
value_type == "Value",
series_type == "Original"
) %>%
group_by(financial_year, loan_type) %>%
summarise(annual_value = sum(housing_finance, na.rm = TRUE), .groups = "drop") %>%
pivot_wider(names_from = loan_type, values_from = annual_value) %>%
mutate(
total_value = investor + owner_occupier,
investor_share = investor / total_value,
start_year = as.integer(str_sub(financial_year, 1, 4))
)
# National comparison data
q3_nat_compare <- q3_hf_nat %>%
select(financial_year, start_year, investor, owner_occupier, investor_share) %>%
left_join(
q3_migration_nat %>%
select(financial_year, pos_nom),
by = "financial_year"
) %>%
mutate(
investor_index = investor / investor[financial_year == "2004-05"] * 100,
owner_index = owner_occupier / owner_occupier[financial_year == "2004-05"] * 100,
migration_index = pos_nom / pos_nom[financial_year == "2004-05"] * 100,
investor_share_index = investor_share / investor_share[financial_year == "2004-05"] * 100
)
q3_nat_value_long <- q3_nat_compare %>%
select(financial_year, start_year, investor_index, owner_index, migration_index) %>%
pivot_longer(
cols = c(investor_index, owner_index, migration_index),
names_to = "series",
values_to = "index_value"
) %>%
mutate(
series = recode(
series,
investor_index = "Investor lending value",
owner_index = "Owner-occupier lending value",
migration_index = "Positive migrant inflows"
)
)
q3_nat_share_long <- q3_nat_compare %>%
select(financial_year, start_year, investor_share_index, migration_index) %>%
pivot_longer(
cols = c(investor_share_index, migration_index),
names_to = "series",
values_to = "index_value"
) %>%
mutate(
series = recode(
series,
investor_share_index = "Investor share of lending",
migration_index = "Positive migrant inflows"
)
)
# Within-state data for robust coefficient plot
q3_dev <- q3_hf_state %>%
select(financial_year, state, investor_gap_pct) %>%
left_join(
q3_migration_state %>%
select(financial_year, state, migration_growth_pct),
by = c("financial_year", "state")
) %>%
filter(!is.na(investor_gap_pct), !is.na(migration_growth_pct)) %>%
group_by(state) %>%
mutate(
investor_gap_dev = investor_gap_pct - mean(investor_gap_pct, na.rm = TRUE),
migration_growth_dev_10 = (migration_growth_pct - mean(migration_growth_pct, na.rm = TRUE)) / 10
) %>%
ungroup()
fit_rlm_coef_q3 <- function(data, outcome_var, predictor_var) {
formula <- as.formula(paste0(outcome_var, " ~ ", predictor_var))
fit <- rlm(formula, data = data)
fit_sum <- summary(fit)
coef_table <- as.data.frame(fit_sum$coefficients)
coef_table$term <- rownames(coef_table)
slope_row <- coef_table %>%
filter(term == predictor_var) %>%
transmute(
estimate = Value,
std.error = `Std. Error`,
conf.low = estimate - 1.96 * std.error,
conf.high = estimate + 1.96 * std.error
)
tibble(
state = unique(data$state),
estimate = slope_row$estimate,
std.error = slope_row$std.error,
conf.low = slope_row$conf.low,
conf.high = slope_row$conf.high
)
}
q3_gap_coef <- q3_dev %>%
group_by(state) %>%
group_modify(~ fit_rlm_coef_q3(.x, "investor_gap_dev", "migration_growth_dev_10")) %>%
ungroup() %>%
mutate(state = factor(state, levels = rev(state_levels)))
#| label: q3-inline-stats
#| include: false
q3_share_2004 <- q3_nat_compare %>%
filter(financial_year == "2004-05") %>%
