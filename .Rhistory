filter(financial_year == "2024-25") %>%
pull(investor_share)
q3_nom_2004 <- q3_nat_compare %>%
filter(financial_year == "2004-05") %>%
pull(pos_nom)
q3_nom_2014 <- q3_nat_compare %>%
filter(financial_year == "2014-15") %>%
pull(pos_nom)
q3_nom_2022 <- q3_nat_compare %>%
filter(financial_year == "2022-23") %>%
pull(pos_nom)
q3_nom_2024 <- q3_nat_compare %>%
filter(financial_year == "2024-25") %>%
pull(pos_nom)
q3_gap_sig_n <- q3_gap_coef %>%
summarise(n_sig = sum(conf.low > 0)) %>%
pull(n_sig)
q3_gap_tas <- q3_gap_coef %>%
filter(state == "Tasmania") %>%
