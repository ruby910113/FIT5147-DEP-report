overseas_migration <- overseas_migration %>%
filter(financial_year >= "2004-05",
financial_year <= "2024-25")
housing_finance <- housing_finance %>%
filter(financial_year >= "2004-05",
financial_year <= "2024-25")
wage_price_index <- wage_price_index %>%
filter(financial_year >= "2004-05",
financial_year <= "2024-25")
visdat::vis_miss(housing_finance)
visdat::vis_miss(overseas_migration)
visdat::vis_miss(wage_price_index)
visdat::vis_miss(housing_finance)
write_csv(overseas_migration, "data/overseas_migration.csv")
write_csv(housing_finance, "data/housing_finance.csv")
write_csv(wage_price_index, "data/wage_price_index.csv")
#| label: fig-hf-missing
#| fig-cap: Missing values in the housing finance dataset across time, state, and loan type
housing_finance_missing <- housing_finance %>%
mutate(
date = make_date(year, month, 1),
missing_status = if_else(is.na(housing_finance), "Missing", "Available"),
state_loan = paste(state, loan_type, sep = " - ")
)
ggplot(housing_finance_missing, aes(x = date, y = fct_rev(state_loan), fill = missing_status)) +
geom_tile(height = 0.8) +
scale_fill_manual(values = c("Missing" = "firebrick", "Available" = "grey85")) +
labs(
title = "Missing values in the housing finance dataset",
x = "Date",
y = "State and loan type",
fill = NULL
) +
theme_minimal(base_size = 12) +
theme(
panel.grid = element_blank(),
axis.text.y = element_text(size = 8),
legend.position = "bottom"
)
#| label: fig-hf-missing-count
#| fig-cap: Number of missing values in the housing finance dataset by state and loan type
housing_finance %>%
group_by(state, loan_type) %>%
summarise(
n_missing = sum(is.na(housing_finance)),
.groups = "drop"
) %>%
mutate(state_loan = paste(state, loan_type, sep = " - ")) %>%
ggplot(aes(x = reorder(state_loan, n_missing), y = n_missing)) +
geom_col(fill = "grey60") +
coord_flip() +
labs(
title = "Number of missing values in the housing finance dataset",
x = NULL,
y = "Number of missing values"
) +
theme_minimal(base_size = 12)
#| label: tbl-hf-series-start
#| tbl-cap: Series start and end dates in the original housing finance workbooks
read_hf_metadata <- function(file_path, loan_type) {
hf_meta <- read_excel(
path = file_path,
sheet = "Data1",
n_max = 10,
col_names = FALSE
)
series_cols <- paste0("series_", seq_len(ncol(hf_meta) - 1))
names(hf_meta) <- c("label", series_cols)
tibble(
series_col = series_cols,
full_name = as.character(unlist(hf_meta[1, -1])),
series_type = as.character(unlist(hf_meta[3, -1])),
series_start = as.Date(unlist(hf_meta[7, -1]), origin = "1970-01-01"),
series_end = as.Date(unlist(hf_meta[8, -1]), origin = "1970-01-01"))
}
owner_meta <- read_excel("data/560104.xlsx", sheet = "Data1", n_max = 10, col_names = FALSE)
investor_meta <- read_excel("data/560114.xlsx", sheet = "Data1", n_max = 10, col_names = FALSE)
extract_hf_series_info <- function(meta_df, loan_type) {
series_cols <- paste0("series_", seq_len(ncol(meta_df) - 1))
names(meta_df) <- c("label", series_cols)
tibble(
series_col = series_cols,
full_name = as.character(unlist(meta_df[1, -1])),
series_type = as.character(unlist(meta_df[3, -1])),
series_start = as.Date(unlist(meta_df[7, -1]), origin = "1970-01-01"),
series_end = as.Date(unlist(meta_df[8, -1]), origin = "1970-01-01"))
) %>%
#| label: tbl-hf-series-start
#| tbl-cap: Series start and end dates in the original housing finance workbooks
read_hf_metadata <- function(file_path, loan_type) {
hf_meta <- read_excel(
path = file_path,
sheet = "Data1",
n_max = 10,
col_names = FALSE
)
series_cols <- paste0("series_", seq_len(ncol(hf_meta) - 1))
names(hf_meta) <- c("label", series_cols)
tibble(
series_col = series_cols,
full_name = as.character(unlist(hf_meta[1, -1])),
series_type = as.character(unlist(hf_meta[3, -1])),
series_start = as.Date(unlist(hf_meta[7, -1]), origin = "1970-01-01"),
series_end = as.Date(unlist(hf_meta[8, -1]), origin = "1970-01-01"))
}
owner_meta <- read_excel("data/560104.xlsx", sheet = "Data1", n_max = 10, col_names = FALSE)
investor_meta <- read_excel("data/560114.xlsx", sheet = "Data1", n_max = 10, col_names = FALSE)
extract_hf_series_info <- function(meta_df, loan_type) {
series_cols <- paste0("series_", seq_len(ncol(meta_df) - 1))
names(meta_df) <- c("label", series_cols)
tibble(
series_col = series_cols,
full_name = as.character(unlist(meta_df[1, -1])),
series_type = as.character(unlist(meta_df[3, -1])),
series_start = as.Date(unlist(meta_df[7, -1]), origin = "1970-01-01"),
series_end = as.Date(unlist(meta_df[8, -1]), origin = "1970-01-01")) %>%
separate(
full_name,
into = c("sector", "collection", "borrower_type", "dwelling_type",
"state", "measure", "value_type", "blank"),
sep = "\\s*;\\s*",
extra = "drop",
fill = "right"
) %>%
mutate(loan_type = loan_type) %>%
group_by(loan_type, value_type) %>%
summarise(
number_of_series = n(),
series_start = format(min(series_start, na.rm = TRUE), "%Y-%m"),
series_end = format(max(series_end, na.rm = TRUE), "%Y-%m"),
.groups = "drop"
)
}
hf_series_summary <- bind_rows(
extract_hf_series_info(owner_meta, "owner_occupier"),
extract_hf_series_info(investor_meta, "investor")
)
#| label: tbl-hf-series-start
#| tbl-cap: Series start and end dates in the original housing finance workbooks
owner_meta <- read_excel("data/560104.xlsx", sheet = "Data1", n_max = 10, col_names = FALSE)
investor_meta <- read_excel("data/560114.xlsx", sheet = "Data1", n_max = 10, col_names = FALSE)
extract_hf_series_info <- function(meta_df, loan_type) {
series_cols <- paste0("series_", seq_len(ncol(meta_df) - 1))
names(meta_df) <- c("label", series_cols)
tibble(
series_col = series_cols,
full_name = as.character(unlist(meta_df[1, -1])),
series_type = as.character(unlist(meta_df[3, -1])),
series_start = as.Date(unlist(meta_df[7, -1])),
series_end = as.Date(unlist(meta_df[8, -1]))
) %>%
separate(
full_name,
into = c("sector", "collection", "borrower_type", "dwelling_type",
"state", "measure", "value_type", "blank"),
sep = "\\s*;\\s*",
extra = "drop",
fill = "right"
) %>%
mutate(loan_type = loan_type) %>%
group_by(loan_type, value_type) %>%
summarise(
number_of_series = n(),
series_start = format(min(series_start, na.rm = TRUE), "%Y-%m"),
series_end = format(max(series_end, na.rm = TRUE), "%Y-%m"),
.groups = "drop"
)
}
hf_series_summary <- bind_rows(
extract_hf_series_info(owner_meta, "owner_occupier"),
extract_hf_series_info(investor_meta, "investor")
)
#| label: tbl-hf-series-start
#| tbl-cap: Series start and end dates in the original housing finance workbooks
#| label: tbl-hf-missing-summary
#| tbl-cap: Availability of observations in the housing finance dataset
hf_missing_summary <- housing_finance %>%
group_by(loan_type, value_type) %>%
summarise(
first_available = min(financial_year[!is.na(housing_finance)], na.rm = TRUE),
last_available = max(financial_year[!is.na(housing_finance)], na.rm = TRUE),
n_missing = sum(is.na(housing_finance)),
n_available = sum(!is.na(housing_finance)),
.groups = "drop"
) %>%
mutate(
loan_type = recode(
loan_type,
owner_occupier = "Owner-occupier",
investor = "Investor"
)
)
hf_missing_summary %>%
kable(
col.names = c("Loan type", "Value type", "First available FY", "Last available FY",
"Missing values", "Available values")
) %>%
kable_styling(full_width = FALSE)
