theme = theme(plot.title = element_text(face = "bold", hjust = 0.5, size = 17))
) &
theme(
legend.position = "bottom",
legend.text = element_text(size = 10)
)
#| label: q3-prepare-data
# State shares of positive migrant inflows
q3_migration_state <- overseas_migration %>%
filter(state %in% state_levels, country_of_birth != "Australia") %>%
mutate(pos_nom = pmax(net_overseas_migration, 0)) %>%
group_by(financial_year, state) %>%
summarise(pos_nom = sum(pos_nom, na.rm = TRUE), .groups = "drop") %>%
group_by(financial_year) %>%
mutate(
migration_share = pos_nom / sum(pos_nom, na.rm = TRUE),
start_year = as.integer(str_sub(financial_year, 1, 4))
) %>%
ungroup()
# State shares of investor lending value
q3_investor_state <- housing_finance %>%
filter(
state %in% state_levels,
loan_type == "investor",
value_type == "Value",
series_type == "Original"
) %>%
group_by(financial_year, state) %>%
summarise(investor_value = sum(housing_finance, na.rm = TRUE), .groups = "drop") %>%
group_by(financial_year) %>%
mutate(
investor_share = investor_value / sum(investor_value, na.rm = TRUE),
start_year = as.integer(str_sub(financial_year, 1, 4))
) %>%
ungroup()
# Divergence = investor lending share - migration share
q3_divergence <- q3_investor_state %>%
left_join(
q3_migration_state %>%
select(financial_year, state, pos_nom, migration_share),
by = c("financial_year", "state")
) %>%
mutate(
divergence_pp = (investor_share - migration_share) * 100,
period = if_else(
start_year <= 2019,
"2004-05 to 2019-20",
"2020-21 to 2024-25"
),
state = factor(state, levels = rev(state_levels))
)
q3_period_summary <- q3_divergence %>%
group_by(state, period) %>%
summarise(mean_divergence = mean(divergence_pp, na.rm = TRUE), .groups = "drop")
q3_period_wide <- q3_period_summary %>%
pivot_wider(names_from = period, values_from = mean_divergence) %>%
rename(
pre_mean = `2004-05 to 2019-20`,
post_mean = `2020-21 to 2024-25`
) %>%
mutate(
change_post = post_mean - pre_mean,
state = factor(state, levels = rev(state_levels))
)
#| label: q3-inline-stats
#| include: false
q3_state_summary <- q3_divergence %>%
group_by(state) %>%
summarise(
mean_divergence = mean(divergence_pp, na.rm = TRUE),
.groups = "drop"
)
q3_max_row <- q3_divergence %>%
slice_max(divergence_pp, n = 1, with_ties = FALSE)
q3_min_row <- q3_divergence %>%
slice_min(divergence_pp, n = 1, with_ties = FALSE)
q3_nsw_mean <- q3_state_summary %>%
filter(state == "New South Wales") %>%
pull(mean_divergence)
q3_qld_mean <- q3_state_summary %>%
filter(state == "Queensland") %>%
pull(mean_divergence)
q3_vic_mean <- q3_state_summary %>%
filter(state == "Victoria") %>%
pull(mean_divergence)
q3_wa_mean <- q3_state_summary %>%
filter(state == "Western Australia") %>%
pull(mean_divergence)
q3_act_mean <- q3_state_summary %>%
filter(state == "Australian Capital Territory") %>%
pull(mean_divergence)
q3_tas_mean <- q3_state_summary %>%
filter(state == "Tasmania") %>%
pull(mean_divergence)
q3_nsw_pre <- q3_period_wide %>%
filter(state == "New South Wales") %>%
pull(pre_mean)
q3_nsw_post <- q3_period_wide %>%
filter(state == "New South Wales") %>%
pull(post_mean)
q3_vic_pre <- q3_period_wide %>%
filter(state == "Victoria") %>%
pull(pre_mean)
q3_vic_post <- q3_period_wide %>%
filter(state == "Victoria") %>%
pull(post_mean)
q3_qld_pre <- q3_period_wide %>%
filter(state == "Queensland") %>%
pull(pre_mean)
q3_qld_post <- q3_period_wide %>%
filter(state == "Queensland") %>%
pull(post_mean)
q3_wa_pre <- q3_period_wide %>%
filter(state == "Western Australia") %>%
pull(pre_mean)
q3_wa_post <- q3_period_wide %>%
filter(state == "Western Australia") %>%
pull(post_mean)
#| label: fig-q3-divergence-heatmap
#| fig-cap: Divergence between investor lending share and migration-demand share across Australian states, 2004-05 to 2024-25. Positive values indicate that a state’s share of investor lending exceeds its share of positive migrant inflows, while negative values indicate the opposite.
#| fig-width: 10
#| fig-height: 5
ggplot(q3_divergence, aes(x = start_year, y = state, fill = divergence_pp)) +
geom_tile(colour = "white", linewidth = 0.2) +
scale_fill_gradient2(
low = "#2166ac",
mid = "white",
high = "#b2182b",
midpoint = 0,
name = "Percentage\npoints"
) +
scale_x_continuous(
breaks = seq(2004, 2024, by = 4),
labels = function(x) paste0(x, "-", str_sub(x + 1, 3, 4))
) +
labs(
title = "Divergence Between Investor Lending and Migration Demand Across States",
x = "Financial year",
y = NULL
) +
theme_minimal(base_size = 11) +
theme(
panel.grid = element_blank(),
plot.title = element_text(face = "bold", hjust = 0.5, size = 16),
axis.text.y = element_text(size = 9)
)
#| label: fig-q3-period-compare
#| fig-cap: Average divergence between investor lending share and migration-demand share before and after 2020-21. Circles show the average for 2004-05 to 2019-20, while triangles show the average for 2020-21 to 2024-25.
#| fig-width: 10
#| fig-height: 5
ggplot(q3_period_wide, aes(y = state)) +
geom_vline(xintercept = 0, linetype = "dashed", colour = "grey50") +
geom_segment(
aes(x = pre_mean, xend = post_mean, yend = state),
colour = "grey70",
linewidth = 1
) +
geom_point(
aes(x = pre_mean, colour = state, shape = "2004-05 to 2019-20"),
size = 2.8
) +
geom_point(
aes(x = post_mean, colour = state, shape = "2020-21 to 2024-25"),
size = 3
) +
scale_colour_manual(values = state_colors, guide = "none") +
scale_shape_manual(
values = c("2004-05 to 2019-20" = 16, "2020-21 to 2024-25" = 17),
name = NULL
) +
labs(
title = "Average Investor–Migration Divergence Before and After 2020-21",
x = "Mean divergence (percentage points)",
y = NULL
) +
theme_minimal(base_size = 11) +
theme(
panel.grid.minor = element_blank(),
plot.title = element_text(face = "bold", hjust = 0.5, size = 16),
legend.position = "bottom"
)
